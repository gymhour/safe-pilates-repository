{
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/api"
        }
    ],
    "functions": {
        "api/cron/checkVencidas.ts": { "maxDuration": 60 },
        "api/cron/daily.ts": { "maxDuration": 60 }
    },
    "crons": [
        {
            "path": "/api/cron/checkVencidas",
            "schedule": "0 4 * * *"
        },
        {
            "path": "/api/cron/daily",
            "schedule": "0 10 * * *"
        }
    ]
}
